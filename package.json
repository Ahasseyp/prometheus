{
  "name": "prometheus",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently --names \"web,api\" --prefix-colors \"blue.bold,green.bold\" \"pnpm --filter @prometheus/web dev\" \"pnpm --filter @prometheus/api dev\"",
    "db:start": "docker compose up -d",
    "db:stop": "docker compose down",
    "db:migrate": "pnpm --filter @prometheus/api exec prisma migrate dev",
    "db:migrate:deploy": "pnpm --filter @prometheus/api exec prisma migrate deploy",
    "db:generate": "pnpm --filter @prometheus/api exec prisma generate",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm --filter @prometheus/domain build && pnpm -r typecheck",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^20.17.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.17.0",
    "eslint-plugin-prettier": "^5.2.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0"
  }
}
