# App
PORT=3000
VITE_API_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://prometheus:prometheus@localhost:5432/prometheus

# Secrets (fill in production/self-hosted values)
JWT_SECRET=
SESSION_SECRET=
ENCRYPTION_KEY=

# Feature flags
# ALLOW_REGISTRATION gates the backend mutation; VITE_ALLOW_REGISTRATION gates the frontend UI.
# They must be kept in sync. Vite only exposes env vars prefixed with VITE_ to the browser.
ALLOW_REGISTRATION=false
VITE_ALLOW_REGISTRATION=false

# External services
OPENAI_API_KEY=
